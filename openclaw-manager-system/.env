# ============================================
# OPENCLAW - DEFAULT PRODUCTION CONFIG
# ============================================
# This file contains default values for OpenClaw deployment.
# Tailscale configuration is handled separately by the module.
#
# Quick start:
#   1. Set TS_AUTHKEY only if you want Tailscale integration
#   2. Run: ./deploy.sh
# ============================================

# --------------------------------------------
# OPENCLAW CONFIGURATION (defaults work for most cases)
# --------------------------------------------
OPENCLAW_CONTAINER_NAME=openclaw
OPENCLAW_IMAGE_NAME=ghcr.io/openclaw/openclaw:latest
OPENCLAW_DATA_DIR=${HOME}/.openclaw
OPENCLAW_PORT=18789
OPENCLAW_BIND_ADDRESS=127.0.0.1

# --------------------------------------------
# TAILSCALE INTEGRATION (optional)
# --------------------------------------------
# Leave TS_AUTHKEY empty to run OpenClaw without Tailscale
# To enable Tailscale Funnel:
#   1. Get auth key from: https://login.tailscale.com/admin/settings/keys
#   2. Set TS_AUTHKEY below
#   3. Run ./deploy.sh or ./openclaw-manager-tailscale.sh start
TS_AUTHKEY=

# Optional: API key for duplicate node cleanup
TS_API_KEY=

# Optional: Tailnet name (auto-detected if empty)
TS_TAILNET=

# Optional: Custom hostname (default: openclaw-funnel)
TS_HOSTNAME=openclaw-funnel

# Optional: Custom container name (default: tailscale-funnel)
TS_CONTAINER_NAME=tailscale-funnel

# --------------------------------------------
# MONITORING (production defaults)
# --------------------------------------------
LOG_LEVEL=info
ENABLE_HEALTH_CHECK=true
