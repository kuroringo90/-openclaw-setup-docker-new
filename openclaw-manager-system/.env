# ============================================
# OPENCLAW + TAILSCALE - DEFAULT PRODUCTION CONFIG
# ============================================
# This file contains default values for production deployment.
# Copy to ~/.openclaw/.env and customize as needed.
#
# Quick start:
#   1. Set TS_AUTHKEY (required)
#   2. Run: ./deploy.sh
# ============================================

# --------------------------------------------
# OPENCLAW CONFIGURATION (defaults work for most cases)
# --------------------------------------------
OPENCLAW_CONTAINER_NAME=openclaw
OPENCLAW_IMAGE_NAME=ghcr.io/openclaw/openclaw:latest
OPENCLAW_DATA_DIR=${HOME}/.openclaw
OPENCLAW_PORT=18789
OPENCLAW_BIND_ADDRESS=127.0.0.1

# --------------------------------------------
# TAILSCALE AUTHENTICATION (REQUIRED - set this!)
# --------------------------------------------
# Get your auth key from: https://login.tailscale.com/admin/settings/keys
# For production, create a pre-authenticated key with limited lifetime
TS_AUTHKEY=

# --------------------------------------------
# TAILSCALE API (optional but recommended)
# --------------------------------------------
# Required for automatic duplicate node cleanup
# Create at: https://login.tailscale.com/admin/settings/keys
TS_API_KEY=

# --------------------------------------------
# TAILNET CONFIGURATION (optional - auto-detected)
# --------------------------------------------
# Leave empty to auto-detect from your Tailscale account
TS_TAILNET=

# Node hostname (will be: openclaw-funnel.<tailnet>.ts.net)
TS_HOSTNAME=openclaw-funnel

# Container name
TS_CONTAINER_NAME=tailscale-funnel

# --------------------------------------------
# SECURITY (production defaults)
# --------------------------------------------
# Bind to localhost only - access via Tailscale Funnel
OPENCLAW_BIND_ADDRESS=127.0.0.1

# Enable Funnel for public HTTPS access
TS_ENABLE_FUNNEL=true

# --------------------------------------------
# MONITORING (production defaults)
# --------------------------------------------
LOG_LEVEL=info
ENABLE_HEALTH_CHECK=true

# --------------------------------------------
# BACKUP (production defaults)
# --------------------------------------------
# Backups stored in: ${OPENCLAW_DATA_DIR}/backups
# Retention: 7 days (configurable in backup.sh)
