# ============================================
# OPENCLAW + TAILSCALE - PRODUCTION CONFIGURATION
# ============================================
# Copy this file to ~/.openclaw/.env
# NEVER commit .env to version control!
#
# This configuration is specific to OpenClaw deployment.
# It uses the standalone tailscale-funnel-compose module.

# --------------------------------------------
# OPENCLAW CONFIGURATION
# --------------------------------------------
# OpenClaw container name
OPENCLAW_CONTAINER_NAME=openclaw

# OpenClaw image to use (pin to digest or a fixed release tag in production)
# Example release tag: ghcr.io/openclaw/openclaw:2026.3.11
# Example digest pin:  ghcr.io/openclaw/openclaw@sha256:f4f1e98439a9880c063ce95a194cdce3988757772fd0ac78ead1f45475006e5e
OPENCLAW_IMAGE_NAME=ghcr.io/openclaw/openclaw@sha256:f4f1e98439a9880c063ce95a194cdce3988757772fd0ac78ead1f45475006e5e

# Data directory for OpenClaw persistence
OPENCLAW_DATA_DIR=${HOME}/.openclaw

# Port OpenClaw listens on (internal)
OPENCLAW_PORT=18789

# Bind address for OpenClaw (production: 127.0.0.1)
# Use 0.0.0.0 only if you need LAN access without Tailscale
OPENCLAW_BIND_ADDRESS=127.0.0.1

# Comma-separated Control UI origins allowed to connect to the gateway.
# Leave empty to auto-derive localhost plus the current Tailscale Funnel URL if available.
# OPENCLAW_ALLOWED_ORIGINS=https://steagent.tail5d495.ts.net

# Comma-separated trusted reverse proxy CIDRs.
# Leave empty to auto-derive localhost plus the current OpenClaw Docker network subnet if available.
# OPENCLAW_TRUSTED_PROXIES=127.0.0.1/32,172.19.0.0/16

# Break-glass only: weakens origin enforcement behind proxies.
# Keep false unless you have a confirmed compatibility blocker.
OPENCLAW_ALLOW_HOST_HEADER_ORIGIN_FALLBACK=false

# --------------------------------------------
# TAILSCALE AUTHENTICATION (REQUIRED)
# --------------------------------------------
# Get your auth key from: https://login.tailscale.com/admin/settings/keys
# For production:
#   - Use ephemeral keys for temporary deployments
#   - Use pre-authenticated keys with limited lifetime for permanent deployments
#   - Never use keys starting with "tskey-auth-" in production
TS_AUTHKEY=

# --------------------------------------------
# TAILSCALE API (FOR AUTOMATION)
# --------------------------------------------
# Required for automatic duplicate node cleanup
# Create at: https://login.tailscale.com/admin/settings/keys
# Permissions: Devices > Delete
TS_API_KEY=

# --------------------------------------------
# TAILNET CONFIGURATION
# --------------------------------------------
# Your Tailnet name (e.g., "example.com" or "github")
# Leave empty to auto-detect
TS_TAILNET=

# Node hostname (must be unique in your tailnet)
# Naming convention: <app>-<env>-funnel
TS_HOSTNAME=openclaw-funnel

# Container name for Tailscale
TS_CONTAINER_NAME=tailscale-funnel

# --------------------------------------------
# TAILSCALE STACK LOCATION
# --------------------------------------------
# Path to tailscale-funnel-compose module
# Auto-detected in this order:
#   1. REPO_TS_STACK_DIR
#   2. ../tailscale-funnel-compose-standalone
#   3. ../tailscale-funnel-compose
#   4. ./tailscale-funnel-compose
#   5. /opt/tailscale-funnel-compose
# For external installation:
# REPO_TS_STACK_DIR=/opt/tailscale-funnel-compose

# --------------------------------------------
# SECURITY SETTINGS
# --------------------------------------------
# Enable Tailscale Funnel (public access)
# Set to false for tailnet-only access
TS_ENABLE_FUNNEL=true

# --------------------------------------------
# MONITORING & LOGGING
# --------------------------------------------
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable health check endpoint
ENABLE_HEALTH_CHECK=true

# --------------------------------------------
# BACKUP CONFIGURATION
# --------------------------------------------
# Directory for backups (default: inside DATA_DIR)
# BACKUP_DIR=${HOME}/.openclaw/backups

# Days to keep backups (default: 7)
# KEEP_BACKUP_DAYS=7
