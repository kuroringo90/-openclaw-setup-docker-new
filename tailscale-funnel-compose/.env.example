# ============================================
# TAILSCALE FUNNEL - STANDALONE CONFIGURATION
# ============================================
# Copy this file to .env and fill in the required values.
# NEVER commit .env to version control!
#
# This configuration is for the standalone Tailscale Funnel module.
# It can be used by any project to expose local services via Tailscale Funnel.

# --------------------------------------------
# REQUIRED: Tailscale Authentication
# --------------------------------------------
# Get your auth key from: https://login.tailscale.com/admin/settings/keys
# For production, create a pre-authenticated key with:
#   - Limited lifetime (e.g., 90 days)
#   - Specific tags (e.g., tag:production)
#   - IP pinning enabled
TS_AUTHKEY=

# --------------------------------------------
# OPTIONAL: Tailscale API Key (for cleanup)
# --------------------------------------------
# Required for automatic duplicate node cleanup.
# Create an API key at: https://login.tailscale.com/admin/settings/keys
# Permissions needed: Devices > Delete
TS_API_KEY=

# --------------------------------------------
# OPTIONAL: Tailnet Configuration
# --------------------------------------------
# Your Tailnet name (e.g., "example.com" or "github")
# If not set, will be auto-detected from the node
TS_TAILNET=

# --------------------------------------------
# NODE IDENTIFICATION
# --------------------------------------------
# Hostname for the Tailscale node (must be unique)
# Naming convention: <service>-funnel-<env>
TS_HOSTNAME=tailscale-funnel

# Container name for Docker
TS_CONTAINER_NAME=tailscale-funnel

# --------------------------------------------
# DEFAULT SERVICE CONFIGURATION
# --------------------------------------------
# Main service exposed through Funnel on path /
# Replace with your service name, port, and path
TS_DEFAULT_SERVICE_NAME=myservice
TS_DEFAULT_SERVICE_PORT=8080
TS_DEFAULT_SERVICE_PATH=/

# Default exposure mode for services added without an explicit mode.
# funnel = public on Internet
# serve  = tailnet-only
TS_DEFAULT_EXPOSURE_MODE=funnel

# --------------------------------------------
# ADVANCED: Tailscale Configuration
# --------------------------------------------
# Extra arguments to pass to tailscaled
# Examples:
#   --advertise-routes=10.0.0.0/8          # Advertise routes
#   --accept-routes=true                    # Accept routes from other nodes
#   --ssh                                   # Enable Tailscale SSH
#   --login-server=https://your-headscale.com  # Self-hosted control server
TS_EXTRA_ARGS=

# --------------------------------------------
# LOGGING & MONITORING
# --------------------------------------------
# Log level: debug, info, warn, error
TS_LOG_LEVEL=info

# Enable metrics endpoint (prometheus format)
TS_ENABLE_METRICS=false
TS_METRICS_PORT=9002
